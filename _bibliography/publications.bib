@article{Milovic2024XSIM,
  title = {{{XSIM}}: {{A}} Structural Similarity Index Measure Optimized for {{MRI QSM}}},
  author = {Milovic, Carlos and Tejos, Cristian and Silva, Javier and Shmueli, Karin and Irarrazaval, Pablo},
  author+an:orcid = {1="http://orcid.org/0000-0002-1196-6703"; 3="http://orcid.org/0000-0002-7276-9033"; 4="http://orcid.org/0000-0001-7520-2975"; 5="http://orcid.org/0000-0002-5186-2642"},
  date = {2024-08-23},
  journaltitle = {Magnetic Resonance in Medicine},
  shortjournal = {Magnetic Resonance in Med},
  volume = {93},
  number = {1},
  pages = {411--421},
  publisher = {Wiley},
  issn = {0740-3194},
  doi = {10.1002/mrm.30271},
  url = {http://dx.doi.org/10.1002/mrm.30271},
  abstract = {{$<$}jats:title{$>$}Abstract{$<$}/jats:title{$><$}jats:sec{$><$}jats:title{$>$}Purpose{$<$}/jats:title{$><$}jats:p{$>$}The structural similarity index measure (SSIM) has become a popular quality metric to evaluate QSM in a way that is closer to human perception than RMS error (RMSE). However, SSIM may overpenalize errors in diamagnetic tissues and underpenalize them in paramagnetic tissues, resulting in biasing. In addition, extreme artifacts may compress the dynamic range, resulting in unrealistically high SSIM scores (hacking). To overcome biasing and hacking, we propose XSIM: SSIM implemented in the native QSM range, and with internal parameters optimized for QSM.{$<$}/jats:p{$><$}/jats:sec{$><$}jats:sec{$><$}jats:title{$>$}Methods{$<$}/jats:title{$><$}jats:p{$>$}We used forward simulations from a COSMOS groundtruth brain susceptibility map included in the 2016 QSM Reconstruction Challenge to investigate the effect of QSM reconstruction errors on the SSIM, XSIM, and RMSE metrics. We also used these metrics to optimize QSM reconstructions of the in vivo challenge data set. We repeated this experiment with the QSM abdominal phantom. To validate the use of XSIM instead of SSIM for QSM quality assessment across a range of different reconstruction techniques/algorithms, we analyzed the reconstructions submitted to the 2019 QSM Reconstruction Challenge 2.0.{$<$}/jats:p{$><$}/jats:sec{$><$}jats:sec{$><$}jats:title{$>$}Results{$<$}/jats:title{$><$}jats:p{$>$}Our experiments confirmed the biasing and hacking effects on the SSIM metric applied to QSM. The XSIM metric was robust to those effects, penalizing the presence of streaking artifacts and reconstruction errors. Using XSIM to optimize QSM reconstruction regularization weights returned less overregularization than SSIM and RMSE.{$<$}/jats:p{$><$}/jats:sec{$><$}jats:sec{$><$}jats:title{$>$}Conclusion{$<$}/jats:title{$><$}jats:p{$>$}XSIM is recommended over traditional SSIM to evaluate QSM reconstructions against a known ground truth, as it avoids biasing and hacking effects and provides a larger dynamic range of scores.{$<$}/jats:p{$><$}/jats:sec{$>$}},
  langid = {english}
}

