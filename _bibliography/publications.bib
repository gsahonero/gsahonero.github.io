  date = {2011-06-11},
  abstract = {Farthest-point optimization of a random point set with 1024 points. Both the global minimum distance {$\delta$}X and the average minimum distance {$\delta$}X increase rapidly using our optimization technique. After one iteration the point set is already well-distributed.}
