@article{Si2025Initial,
  title = {Initial Experience of Cardiac {$<$}scp{$>$}{{T}}{$<$}/Scp{$>$} {$_1$} {{$\rho$}} Mapping at 0.55 {$<$}scp{$>$}{{T}}{$<$}/Scp{$>$} : {{Continuous}} Wave versus Adiabatic Spinlock Preparation Pulses},
  author = {Si, Dongyue and Crabb, Michael G. and Littlewood, Simon J. and Kunze, Karl P. and Varghese, Juliet and Binzel, Katherine and Khan, Mahmood and Simonetti, Orlando P. and Prieto, Claudia and Botnar, Ren\'e M.},
  author+an:orcid = {1="https://orcid.org/0000-0002-0080-3052"; 2="https://orcid.org/0000-0002-7919-9731"; 8="https://orcid.org/0000-0002-8994-0095"},
  date = {2025-05-20},
  journaltitle = {Magnetic Resonance in Medicine},
  shortjournal = {Magnetic Resonance in Med},
  volume = {94},
  number = {4},
  pages = {1644--1653},
  publisher = {Wiley},
  issn = {0740-3194},
  doi = {10.1002/mrm.30582},
  url = {http://dx.doi.org/10.1002/mrm.30582},
  abstract = {{$<$}jats:title{$>$}Abstract{$<$}/jats:title{$>$} {$<$}jats:sec{$>$} {$<$}jats:title{$>$}Purpose{$<$}/jats:title{$>$} {$<$}jats:p{$>$} To propose and validate a cardiac T {$<$}jats:sub{$>$}1{$<$}/jats:sub{$>$} {$\rho$} mapping sequence at 0.55 T comparing continuouswave and adiabatic spinlock (SL) preparation pulses. {$<$}/jats:p{$>$} {$<$}/jats:sec{$>$} {$<$}jats:sec{$>$} {$<$}jats:title{$>$}Methods{$<$}/jats:title{$>$} {$<$}jats:p{$>$} The proposed 2D sequence acquires four singleshot balanced SSFP readout images with differing contrasts in a single breathhold. The first three images are prepared with T {$<$}jats:sub{$>$}1{$<$}/jats:sub{$>$} {$\rho$} preparation pulses with different durations, while the last image uses a saturation pulse immediately before data acquisition. The T {$<$}jats:sub{$>$}1{$<$}/jats:sub{$>$} {$\rho$} map is calculated using a 3parameter fitting method. Bloch equation simulations were performed to optimize the parameters of the adiabaticSL pulses. Phantom studies and in vivo experiments in 10 healthy volunteers, a porcine myocardial infarction model, and a patient with suspected hypertrophic cardiomyopathy were performed to validate the performance of the proposed adiabatic T {$<$}jats:sub{$>$}1{$<$}/jats:sub{$>$} {$\rho$} (T {$<$}jats:sub{$>$}1{$<$}/jats:sub{$>$} {$\rho$} {$<$}jats:sub{$>$}Ad{$<$}/jats:sub{$>$} ) mapping in comparison with conventional continuouswave T {$<$}jats:sub{$>$}1{$<$}/jats:sub{$>$} {$\rho$} (T {$<$}jats:sub{$>$}1{$<$}/jats:sub{$>$} {$\rho$} {$<$}jats:sub{$>$}CW{$<$}/jats:sub{$>$} ) mapping. {$<$}/jats:p{$>$} {$<$}/jats:sec{$>$} {$<$}jats:sec{$>$} {$<$}jats:title{$>$}Results{$<$}/jats:title{$>$} {$<$}jats:p{$>$} The adiabaticSL pulse with simulationoptimized parameters demonstrated robust performance despite B {$<$}jats:sub{$>$}0{$<$}/jats:sub{$>$} and B {$<$}jats:sub{$>$}1{$<$}/jats:sub{$>$} field inhomogeneities. Phantom T {$<$}jats:sub{$>$}1{$<$}/jats:sub{$>$} {$\rho$} {$<$}jats:sub{$>$}CW{$<$}/jats:sub{$>$} and T {$<$}jats:sub{$>$}1{$<$}/jats:sub{$>$} {$\rho$} {$<$}jats:sub{$>$}Ad{$<$}/jats:sub{$>$} mapping exhibited comparable precision. In vivo experiments on healthy volunteers showed that myocardial T {$<$}jats:sub{$>$}1{$<$}/jats:sub{$>$} {$\rho$} {$<$}jats:sub{$>$}Ad{$<$}/jats:sub{$>$} is higher than T {$<$}jats:sub{$>$}1{$<$}/jats:sub{$>$} {$\rho$} {$<$}jats:sub{$>$}CW{$<$}/jats:sub{$>$} (106.1 \textpm{} 7.1 vs. 47.0 \textpm{} 5.1 ms, {$<$}jats:italic{$>$}p{$<$}/jats:italic{$>$} \&lt; 0.01) with better precision (11.4{$<$}jats:italic{$>$}p{$<$}/jats:italic{$>$} \&lt; 0.01) and less spatial variation (10.9{$<$}jats:italic{$>$}p{$<$}/jats:italic{$>$} \&lt; 0.01). Both T {$<$}jats:sub{$>$}1{$<$}/jats:sub{$>$} {$\rho$} {$<$}jats:sub{$>$}CW{$<$}/jats:sub{$>$} and T {$<$}jats:sub{$>$}1{$<$}/jats:sub{$>$} {$\rho$} {$<$}jats:sub{$>$}Ad{$<$}/jats:sub{$>$} mapping agreed with late gadolinium enhancement findings in the porcine model and the patient, and exhibited improved contrast compared to T {$<$}jats:sub{$>$}1{$<$}/jats:sub{$>$} and T {$<$}jats:sub{$>$}2{$<$}/jats:sub{$>$} mapping. {$<$}/jats:p{$>$} {$<$}/jats:sec{$>$} {$<$}jats:sec{$>$} {$<$}jats:title{$>$}Conclusion{$<$}/jats:title{$>$} {$<$}jats:p{$>$} Both T {$<$}jats:sub{$>$}1{$<$}/jats:sub{$>$} {$\rho$} {$<$}jats:sub{$>$}CW{$<$}/jats:sub{$>$} and T {$<$}jats:sub{$>$}1{$<$}/jats:sub{$>$} {$\rho$} {$<$}jats:sub{$>$}Ad{$<$}/jats:sub{$>$} are promising for noncontrast detection of various cardiomyopathies at 0.55 T, but T {$<$}jats:sub{$>$}1{$<$}/jats:sub{$>$} {$\rho$} {$<$}jats:sub{$>$}Ad{$<$}/jats:sub{$>$} demonstrates better spatial uniformity than T {$<$}jats:sub{$>$}1{$<$}/jats:sub{$>$} {$\rho$} {$<$}jats:sub{$>$}CW{$<$}/jats:sub{$>$} . {$<$}/jats:p{$>$} {$<$}/jats:sec{$>$}},
  langid = {english}
}

