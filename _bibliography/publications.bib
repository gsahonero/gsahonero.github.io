@article{Hernaez2021Mediterranean,
  title = {Mediterranean {{Diet Maintained Platelet Count}} within a {{Healthy Range}} and {{Decreased Thrombocytopenia-Related Mortality Risk}}: {{A Randomized Controlled Trial}}},
  shorttitle = {Mediterranean {{Diet Maintained Platelet Count}} within a {{Healthy Range}} and {{Decreased Thrombocytopenia-Related Mortality Risk}}},
  author = {Hern\'aez, \'Alvaro and Lassale, Camille and Castro-Barquero, Sara and Ros, Emilio and Tresserra-Rimbau, Anna and Casta\~ner, Olga and Pint\'o, Xavier and V\'azquez-Ruiz, Zenaida and Sorl\'i, Jos\'e V. and Salas-Salvad\'o, Jordi and Lapetra, Jos\'e and G\'omez-Gracia, Enrique and Alonso-G\'omez, \'Angel M. and Fiol, Miquel and Serra-Majem, Lluis and Sacanella, Emilio and Razquin, Cristina and Corella, Dolores and Guasch-Ferr\'e, Marta and Cof\'an, Montserrat and Estruch, Ram\'on},
  author+an:orcid = {1="https://orcid.org/0000-0001-8593-1477"; 2="https://orcid.org/0000-0002-9340-2708"; 3="https://orcid.org/0000-0002-6876-5443"; 5="https://orcid.org/0000-0002-7022-9041"; 6="https://orcid.org/0000-0003-3169-997X"; 7="https://orcid.org/0000-0002-2216-2444"; 8="https://orcid.org/0000-0002-6828-9627"; 9="https://orcid.org/0000-0002-0130-2006"; 10="https://orcid.org/0000-0003-2700-7459"; 13="https://orcid.org/0000-0003-2945-7509"; 16="https://orcid.org/0000-0001-8018-1523"; 17="https://orcid.org/0000-0003-3480-2645"; 18="https://orcid.org/0000-0002-2366-4104"; 19="https://orcid.org/0000-0001-8525-1404"; 20="https://orcid.org/0000-0002-1895-5644"; 21="https://orcid.org/0000-0003-1260-4445"},
  date = {2021-02-08},
  journaltitle = {Nutrients},
  shortjournal = {Nutrients},
  volume = {13},
  number = {2},
  pages = {559},
  publisher = {MDPI AG},
  issn = {2072-6643},
  doi = {10.3390/nu13020559},
  url = {https://www.mdpi.com/2072-6643/13/2/559},
  urldate = {2026-03-13},
  abstract = {There is little information on the dietary modulation of thrombosis-related risk factors such as platelet count. We aimed to assess the effects of Mediterranean diet (MedDiet) on platelet count and related outcomes in an older population at high cardiovascular risk. In participants of the PREDIMED (PREvenci\'on con DIeta MEDiterr\'anea) study, we assessed whether an intervention with a MedDiet enriched with extra-virgin olive oil or nuts, relative to a low-fat control diet, modulated platelet count (n = 4189), the risk of developing thrombocytosis and thrombocytopenia (n = 3086), and the association between these alterations and all-cause mortality (median follow-up time: 3.0 years). Although platelet count increased over time (+0.98{$\cdot$}109 units/L{$\cdot$}year [95\% confidence interval: 0.12; 1.84]), MedDiet interventions moderated this increase, particularly in individuals with near-high baseline count (both MedDiets combined: -3.20{$\cdot$}109 units/L{$\cdot$}year [-5.81; -0.59]). Thrombocytopenia incidence was lower in the MedDiet interventions (incidence rates: 2.23\% in control diet, 0.91\% in MedDiets combined; hazard ratio: 0.44 [0.23; 0.83]). Finally, thrombocytopenia was associated with a higher risk of all-cause mortality (hazard ratio: 4.71 [2.69; 8.24]), but this relationship was attenuated in those allocated to MedDiet (p-interaction = 0.018). In brief, MedDiet maintained platelet counts within a healthy range and attenuated platelet-related mortality in older adults at high cardiovascular risk.},
  langid = {english}
}

@inproceedings{hernandezImprovingImageQuality2021,
