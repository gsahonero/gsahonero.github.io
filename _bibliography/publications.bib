@inproceedings{Nasonov2024Numerical,
  title = {Numerical {{Optimization}} of {{Multichannel Rx-only RF Coil}} for {{Parallel Imaging}} at 0.{{07T}}},
  booktitle = {2024 {{IEEE Ural-Siberian Conference}} on {{Biomedical Engineering}}, {{Radioelectronics}} and {{Information Technology}} ({{USBEREIT}})},
  author = {Nasonov, Aleksei and Solomakha, Georgiy and Hurshkainen, Anna},
  date = {2024-05-13},
  pages = {308--310},
  publisher = {IEEE},
  location = {Yekaterinburg, Russian Federation},
  doi = {10.1109/USBEREIT61901.2024.10584061},
  url = {https://ieeexplore.ieee.org/document/10584061/},
  urldate = {2026-03-13},
  abstract = {The concept of portable ultra-low-field MRI has been actively studied in the past few years. Many approaches focused on using of different software methods for image reconstruction, post-processing and noise reduction. Signal-to-noise ration (SNR) of images could be also enhanced by improving hardware of low-field MRI system. In this work, we propose a method to improve the performance of ultralow-field head MRI by using multichannel Rx arrays combined with parallel imaging techniques. We designed three different Rx-only four-channel array configurations aiming to minimize g-factor and maximize SNR compared to single-channel Tx/Rx solenoid coil. Using the results of numerical electromagnetic simulations, individual sensitivity profiles of array elements were obtained in order to calculate SNR and g-factor of simulated arrays. As a result, a four-channel Rx-array coil with a low g-factor for ultra-low field head MRI has been designed. Using a four-channel Rx-only array with proposed geometry will allow to reduce image acquisition time by using parallel imaging in ultra-low field MRI.},
  eventtitle = {2024 {{IEEE Ural-Siberian Conference}} on {{Biomedical Engineering}}, {{Radioelectronics}} and {{Information Technology}} ({{USBEREIT}})},
  isbn = {979-8-3503-6289-3},
  langid = {english}
}

@article{Nayak2020RealTime,
  title = {{{RealTime Magnetic Resonance Imaging}}},
  author = {Nayak, Krishna S. and Lim, Yongwan and CampbellWashburn, Adrienne E. and Steeden, Jennifer},
  date = {2020-12-09},
  journaltitle = {Journal of Magnetic Resonance Imaging},
  shortjournal = {Magnetic Resonance Imaging},
  volume = {55},
  number = {1},
  pages = {81--99},
  publisher = {Wiley},
  issn = {1053-1807},
  doi = {10.1002/jmri.27411},
  url = {http://dx.doi.org/10.1002/jmri.27411},
  urldate = {2026-03-13},
  abstract = {{$<$}jats:sec{$><$}jats:label /{$><$}jats:p{$>$}Realtime magnetic resonance imaging (RTMRI) allows for imaging dynamic processes as they occur, without relying on any repetition or synchronization. This is made possible by modern MRI technology such as fastswitching gradients and parallel imaging. It is compatible with many (but not all) MRI sequences, including spoiled gradient echo, balanced steadystate free precession, and singleshot rapid acquisition with relaxation enhancement. RTMRI has earned an important role in both diagnostic imaging and image guidance of invasive procedures. Its unique diagnostic value is prominent in areas of the body that undergo substantial and often irregular motion, such as the heart, gastrointestinal system, upper airway vocal tract, and joints. Its value in interventional procedure guidance is prominent for procedures that require multiple forms of softtissue contrast, as well as flow information. In this review, we discuss the history of RTMRI, fundamental tradeoffs, enabling technology, established applications, and current trends.{$<$}/jats:p{$><$}/jats:sec{$><$}jats:sec{$><$}jats:title{$>$}Level of Evidence{$<$}/jats:title{$><$}jats:p{$>$}5{$<$}/jats:p{$><$}/jats:sec{$><$}jats:sec{$><$}jats:title{$>$}Technical Efficacy Stage{$<$}/jats:title{$><$}jats:p{$>$}1{$<$}/jats:p{$><$}/jats:sec{$>$}},
  langid = {english}
}

@article{Nayak2023Body,
  title = {Body Composition Profiling at 0.{{55T}}: {{Feasibility}} and Precision},
  author = {Nayak, Krishna S. and Cui, Sophia X. and Tasdelen, Bilal and Yagiz, Ecrin and Weston, Sarah and Zhong, Xiaodong and Ahlgren, Andr\'e},
  author+an:orcid = {1="http://orcid.org/0000-0001-5735-3550"; 2="http://orcid.org/0000-0002-5133-4903"; 6="http://orcid.org/0000-0001-8355-5279"},
  date = {2023-05},
  journaltitle = {Magnetic Resonance in Medicine},
  shortjournal = {Magnetic Resonance in Med},
  volume = {90},
  number = {3},
  pages = {1114--1120},
  publisher = {Wiley},
  issn = {0740-3194},
  doi = {10.1002/mrm.29682},
  url = {http://dx.doi.org/10.1002/mrm.29682},
  abstract = {{$<$}jats:sec{$><$}jats:title{$>$}Purpose{$<$}/jats:title{$><$}jats:p{$>$}Body composition MRI captures the distribution of fat and lean tissues throughout the body, and provides valuable biomarkers of obesity, metabolic disease, and muscle disorders, as well as risk assessment. Highly reproducible protocols have been developed for 1.5T and 3T MRI. The purpose of this work was to demonstrate the feasibility and test--retest repeatability of MRI body composition profiling on a 0.55T wholebody system.{$<$}/jats:p{$><$}/jats:sec{$><$}jats:sec{$><$}jats:title{$>$}Methods{$<$}/jats:title{$><$}jats:p{$>$}Healthy adult volunteers were scanned on a wholebody 0.55T MRI system using the integrated body RF coil. Experiments were performed to refine parameter settings such as TEs, resolution, flip angle, bandwidth, acceleration, and oversampling factors. The final protocol was evaluated using a test--retest study with subject removal and replacement in 10 adult volunteers (5 M/5F, age 25--60, body mass index 20--30).{$<$}/jats:p{$><$}/jats:sec{$><$}jats:sec{$><$}jats:title{$>$}Results{$<$}/jats:title{$><$}jats:p{$>$}Compared to 1.5T and 3T, the optimal flip angle at 0.55T was higher (15{$^\circ$}), due to the shorter T1 times, and the optimal echo spacing was larger, due to smaller chemical shift between water and fat. Overall image quality was comparable to conventional field strengths, with no significant issues with fat/water swapping or inadequate SNR. Repeatability coefficient of visceral fat, subcutaneous fat, total thigh muscle volume, muscle fat infiltration, and liver fat were 11.8 cL (2.2},
  langid = {english}
}

@article{Negnevitsky2023MaRCoS,
  title = {{{MaRCoS}}, an Open-Source Electronic Control System for Low-Field {{MRI}}},
  author = {Negnevitsky, Vlad and Vives-Gilabert, Yolanda and Algar\'in, Jos\'e M. and Craven-Brightman, Lincoln and Pellicer-Guridi, Rub\'en and O'Reilly, Thomas and Stockmann, Jason P. and Webb, Andrew and Alonso, Joseba and Menk\"uc, Benjamin},
  date = {2023-05},
  journaltitle = {J. Magn. Reson.},
  shortjournal = {Journal of Magnetic Resonance},
  volume = {350},
  eprint = {37001194},
  eprinttype = {pubmed},
  pages = {107424},
  publisher = {Elsevier BV},
  issn = {10907807},
  doi = {10.1016/j.jmr.2023.107424},
  url = {https://linkinghub.elsevier.com/retrieve/pii/S1090780723000599},
  urldate = {2026-03-13},
  abstract = {Every magnetic resonance imaging (MRI) device requires an electronic control system that handles pulse sequences and signal detection and processing. Here we provide details on the architecture and performance of MaRCoS, a MAgnetic Resonance COntrol System developed by an open international community of low-field MRI researchers. MaRCoS is inexpensive and can handle cycle-accurate sequences without hard length limitations, rapid bursts of events, and arbitrary waveforms. It has also been readily adapted to meet the requirements of the various academic and private institutions participating in its development. We describe the MaRCoS hardware, firmware and software that enable all of the above, including a Python-based graphical user interface for pulse sequence implementation, data processing and image reconstruction.},
  langid = {english}
}

@article{Neves2024Fully,
  title = {Fully Automated Planning for Anatomical Fetal Brain {{MRI}} on 0.{{55T}}},
  author = {Neves Silva, Sara and McElroy, Sarah and Aviles Verdera, Jordina and Colford, Kathleen and St Clair, Kamilah and TomiTricot, Raphael and Uus, Alena and Ozenne, Val\'ery and Hall, Megan and Story, Lisa and Pushparajah, Kuberan and Rutherford, Mary A. and Hajnal, Joseph V. and Hutter, Jana},
  author+an:orcid = {1="http://orcid.org/0009-0009-7520-081X"; 2="http://orcid.org/0000-0002-4271-5931"; 3="http://orcid.org/0009-0007-7575-4244"; 7="http://orcid.org/0000-0001-5796-2145"; 14="http://orcid.org/0000-0003-3476-3500"},
  date = {2024-04-22},
  journaltitle = {Magnetic Resonance in Medicine},
  shortjournal = {Magnetic Resonance in Med},
  volume = {92},
  number = {3},
  pages = {1263--1276},
  publisher = {Wiley},
  issn = {0740-3194},
  doi = {10.1002/mrm.30122},
  url = {http://dx.doi.org/10.1002/mrm.30122},
  abstract = {{$<$}jats:title{$>$}Abstract{$<$}/jats:title{$><$}jats:sec{$><$}jats:title{$>$}Purpose{$<$}/jats:title{$><$}jats:p{$>$}Widening the availability of fetal MRI with fully automatic realtime planning of radiological brain planes on 0.55T MRI.{$<$}/jats:p{$><$}/jats:sec{$><$}jats:sec{$><$}jats:title{$>$}Methods{$<$}/jats:title{$><$}jats:p{$>$}Deep learningbased detection of key brain landmarks on a wholeuterus echo planar imaging scan enables the subsequent fully automatic planning of the radiological singleshot Turbo Spin Echo acquisitions. The landmark detection pipeline was trained on over 120 datasets from varying field strength, echo times, and resolutions and quantitatively evaluated. The entire automatic planning solution was tested prospectively in nine fetal subjects between 20 and 37 weeks. A comprehensive evaluation of all steps, the distance between manual and automatic landmarks, the planning quality, and the resulting image quality was conducted.{$<$}/jats:p{$><$}/jats:sec{$><$}jats:sec{$><$}jats:title{$>$}Results{$<$}/jats:title{$><$}jats:p{$>$}Prospective automatic planning was performed in realtime without latency in all subjects. The landmark detection accuracy was 4.2 2.6 mm for the fetal eyes and 6.5 3.2 for the cerebellum, planning quality was 2.4/3 (compared to 2.6/3 for manual planning) and diagnostic image quality was 2.2 compared to 2.1 for manual planning.{$<$}/jats:p{$><$}/jats:sec{$><$}jats:sec{$><$}jats:title{$>$}Conclusions{$<$}/jats:title{$><$}jats:p{$>$}Realtime automatic planning of all three key fetal brain planes was successfully achieved and will pave the way toward simplifying the acquisition of fetal MRI thereby widening the availability of this modality in nonspecialist centers.{$<$}/jats:p{$><$}/jats:sec{$>$}},
  langid = {english}
}

@misc{Nguyen101Sampling,
  title = {Sampling {{Time Considerations}} for {{T1}} Map Acquisition on the {{64mT Hyperfine Swoop}} System: {{A Phantom Evaluation Study}}},
  author = {Nguyen', Vivian S and Ragunathan, Sudarshan and Carroll', Timothy J and Javed\textregistered, Adil and Vaicik', Marcella K and Georgiadis', John G and Kawaji'?, Keigo},
  date = {0101-01-01},
  abstract = {T1 maps provide quantitative relaxometric measures of tissue responses that may carry correlative indices of specific disease indications. On the recently commercialized 64mT system (Hyperfine Inc.), little has been reported regarding both clinical T1 relaxometric normal values in presence of Gadolinium-based contrast and relevant acquisition schemes with Gd contrast enhancement. In this study, we examine an array of Gadolinium-doped vials that represent 10-5000 fold dilution in the vasculature using an Inversion-Recovery FSE acquisition to gain key insights on: a) anticipated normal values in presence of Gd, b) conventional fitting algorithm performance, and c) potential inferences on inversion timing selection.}
}

@article{Nguyen2020Applying,
  title = {Applying {{Artificial Intelligence}} to {{Mitigate Effects}} of {{Patient Motion}} or {{Other Complicating Factors}} on {{Image Quality}}},
  author = {Nguyen, Xuan V. and Oztek, Murat Alp and Nelakurti, Devi D. and Brunnquell, Christina L. and Mossa-Basha, Mahmud and Haynor, David R. and Prevedello, Luciano M.},
  date = {2020-06-05},
  journaltitle = {Topics in Magnetic Resonance Imaging},
  volume = {29},
  number = {4},
  pages = {175--180},
  publisher = {Ovid Technologies (Wolters Kluwer Health)},
  issn = {0899-3459},
  doi = {10.1097/rmr.0000000000000249},
  url = {http://dx.doi.org/10.1097/RMR.0000000000000249},
  abstract = {{$<$}jats:sec{$><$}jats:title{$>$}Abstract{$<$}/jats:title{$><$}jats:p{$>$}Artificial intelligence, particularly deep learning, offers several possibilities to improve the quality or speed of image acquisition in magnetic resonance imaging (MRI). In this article, we briefly review basic machine learning concepts and discuss commonly used neural network architectures for image-to-image translation. Recent examples in the literature describing application of machine learning techniques to clinical MR image acquisition or postprocessing are discussed. Machine learning can contribute to better image quality by improving spatial resolution, reducing image noise, and removing undesired motion or other artifacts. As patients occasionally are unable to tolerate lengthy acquisition times or gadolinium agents, machine learning can potentially assist MRI workflow and patient comfort by facilitating faster acquisitions or reducing exogenous contrast dosage. Although artificial intelligence approaches often have limitations, such as problems with generalizability or explainability, there is potential for these techniques to improve diagnostic utility, throughput, and patient experience in clinical MRI practice.{$<$}/jats:p{$><$}/jats:sec{$>$}},
  langid = {english}
}

