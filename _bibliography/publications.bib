@misc{Baljer2024Multi,
  title = {Multi-Orientation {{U-Net}} for {{Super-Resolution}} of {{Ultra-Low-Field Paediatric MRI}}},
  author = {Baljer, Levente and Zhang, Yiqi and Bourke, Niall J and Donald, Kirsten A and Bradford, Layla E and Ringshaw, Jessica E and Williams, Simone R and Deoni, Sean Cl and Williams, Steven Cr and Sa, Khula and Team, Study and V\'a\v sa, Franti\v sek and Moran, Rosalyn J},
