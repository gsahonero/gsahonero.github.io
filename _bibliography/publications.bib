@article{liangFullyAutomatedSample2021,
  title = {Fully {{Automated Sample Processing}} and {{Analysis Workflow}} for {{Low-Input Proteome Profiling}}},
  author = {Liang, Yiran and Acor, Hayden and McCown, Michaela A. and Nwosu, Andikan J. and Boekweg, Hannah and Axtell, Nathaniel B. and Truong, Thy and Cong, Yongzheng and Payne, Samuel H. and Kelly, Ryan T.},
