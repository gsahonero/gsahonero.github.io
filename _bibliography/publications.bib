@article{Martinez2024EPI,
  title = {{{EPI}} Proton Resonant Frequency Temperature Mapping at 0.{{5T}} in the Brain: {{Comparison}} to Singleecho Gradient Recalled Echo},
  author = {Martinez, Diego F. and Wiens, Curtis N. and Harris, Chad T. and Handler, William B. and Chronik, Blaine A.},
