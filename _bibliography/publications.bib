@article{Altermatt2018Design,
  title = {Design and Construction of an Innovative Brain Phantom Prototype for {{MRI}}},
  author = {Altermatt, Anna and Santini, Francesco and Deligianni, Xeni and Magon, Stefano and Sprenger, Till and Kappos, Ludwig and Cattin, Philippe and Wuerfel, Jens and Gaetano, Laura},
  date = {2018-09-17},
  journaltitle = {Magnetic Resonance in Medicine},
  shortjournal = {Magnetic Resonance in Med},
  volume = {81},
  number = {2},
  pages = {1165--1171},
  publisher = {Wiley},
  issn = {0740-3194},
  doi = {10.1002/mrm.27464},
  url = {http://dx.doi.org/10.1002/mrm.27464},
  abstract = {{$<$}jats:sec{$><$}jats:title{$>$}Purpose{$<$}/jats:title{$><$}jats:p{$>$}The purpose of this project was to construct a physical brain phantom for MRI, mimicking structure and T{$<$}jats:sub{$>$}1{$<$}/jats:sub{$>$} relaxation properties of white matter (WM) and gray matter (GM).{$<$}/jats:p{$><$}/jats:sec{$><$}jats:sec{$><$}jats:title{$>$}Methods{$<$}/jats:title{$><$}jats:p{$>$}The phantom design comprised 2 compartments, 1 resembling the WM and 1 resembling the GM. Their T{$<$}jats:sub{$>$}1{$<$}/jats:sub{$>$} relaxation times, as assessed using an inversion recovery turbo spin echo sequence, were reproduced using an agar gel doped with contrast agent (CA) and their folding patterns were simulated through a moldingcasting procedure using 3Dprinted casts and flexible silicone molds. Three versions of the assembling procedure were adopted to build: Phantom1 without any separation; Phantom2 with a varnish layer; and Phantom3 with a thin wax layer between the compartments.{$<$}/jats:p{$><$}/jats:sec{$><$}jats:sec{$><$}jats:title{$>$}Results{$<$}/jats:title{$><$}jats:p{$>$}Phantom1 was characterized by an immediate diffusion of CA between the 2 compartments. Phantom2 and Phantom3, instead, showed relaxation times and shape comparable with the target ones identified in a healthy control subject (WM: 754 \textpm{} 40 ms; GM: 1277 \textpm{} 96 ms). Moreover, both compartments revealed intact gyri and sulci. However, the diffusion of CA made Phantom2 stable only for a short period of time. Phantom3 showed stability within a time window of several days but the wax layer between the WM and GM was visible in the MRI.{$<$}/jats:p{$><$}/jats:sec{$><$}jats:sec{$><$}jats:title{$>$}Conclusion{$<$}/jats:title{$><$}jats:p{$>$}Structural and intensity properties of the constructed phantoms are useful in evaluating and validating steps from image acquisition to image processing. Moreover, the described constructing procedure and its modular design make it adjustable to a variety of applications.{$<$}/jats:p{$><$}/jats:sec{$>$}},
  langid = {english}
}

@article{Alves2024Deep,
  title = {Deep {{Dive}} into {{MRI}}: {{Exploring Deep Learning Applications}} in 0.{{55T}} and {{7T MRI}}},
  author = {Alves, Ana Carolina and Ferreira, Andr\'e and Puladi, Behrus and Egger, Jan and Alves, Victor},
  date = {2024},
  publisher = {arXiv},
  doi = {10.48550/ARXIV.2407.01318},
  url = {https://arxiv.org/abs/2407.01318},
  abstract = {The development of magnetic resonance imaging (MRI) for medical imaging has provided a leap forward in diagnosis, providing a safe, non-invasive alternative to techniques involving ionising radiation exposure for diagnostic purposes. It was described by Block and Purcel in 1946, and it was not until 1980 that the first clinical application of MRI became available. Since that time the MRI has gone through many advances and has altered the way diagnosing procedures are performed. Due to its ability to improve constantly, MRI has become a commonly used practice among several specialisations in medicine. Particularly starting 0.55T and 7T MRI technologies have pointed out enhanced preservation of image detail and advanced tissue characterisation. This review examines the integration of deep learning (DL) techniques into these MRI modalities, disseminating and exploring the study applications. It highlights how DL contributes to 0.55T and 7T MRI data, showcasing the potential of DL in improving and refining these technologies. The review ends with a brief overview of how MRI technology will evolve in the coming years.},
  version = {1}
}

