  title = {Multi-Echo {{RF}} Spatial Phase Encoding for Gradient-Free Imaging in a Nonuniform {{B0-field}} at Low-Field},
  author = {Selvaganesan, Kartiga and Ha, Yonghyun and Sun, Chenhao and Samardzija, Anja and Zhang, Zhehong and Sun, Heng and Galiana, Gigi and Constable, Todd},
