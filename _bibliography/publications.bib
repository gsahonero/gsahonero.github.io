@article{Aguilera2020Etica,
  title = {\'Etica, Derecho y Regulaci\'on de La Investigaci\'on Biom\'edica En {{Chile}}},
  author = {Aguilera, Bernardo and L\'opez, Gonzalo and Portales, Bernardita and Reyes, Marcela and Vrsalovic, Joaqu\'in},
  author+an:orcid = {1="https://orcid.org/0000-0001-9138-5003"; 2="https://orcid.org/0000-0001-6469-058X"; 3="https://orcid.org/0000-0002-5348-7284"; 4="https://orcid.org/0000-0002-1200-2666"; 5="https://orcid.org/0000-0002-0323-1491"},
  date = {2020-06},
  journaltitle = {Revista Bio\'etica},
  shortjournal = {Rev. Bio\'et.},
  volume = {28},
  number = {2},
  pages = {239--248},
  publisher = {FapUNIFESP (SciELO)},
  issn = {1983-8034},
  doi = {10.1590/1983-80422020282385},
  url = {http://dx.doi.org/10.1590/1983-80422020282385},
  abstract = {{$<$}jats:p{$>$}Resumen El presente trabajo analiza la relaci\'on entre \'etica y derecho en la regulaci\'on de la investigaci\'on biom\'edica en Chile. Para ello, se lleva a cabo un estudio comparativo entre el marco legal chileno y las principales normativas \'eticas internacionales ( Declaraci\'on de Helsinki y Pautas del Consejo de Organizaciones Internacionales de las Ciencias M\'edicas), teniendo como referente los requisitos para evaluar una investigaci\'on biom\'edica propuestos por Emanuel, Wendler y Grady. Se examinan y comentan tensiones e inconsistencias entre estos \'ambitos regulatorios, en particular aquellas donde la legislaci\'on chilena tiene vac\'ios, falencias o es m\'as exigente que el est\'andar \'etico internacional. Se concluye con sugerencias para mejorar la regulaci\'on jur\'idica chilena, entre las que se incluyen fortalecer el rol deliberativo de los comit\'es \'etico-cient\'ificos y sistematizar el marco relacionado con investigaci\'on con el fin de lograr un cuerpo legal m\'as org\'anico y completo.{$<$}/jats:p{$>$}}
}

