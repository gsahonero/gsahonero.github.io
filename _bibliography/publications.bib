@article{Mayer2007Measuring,
  title = {Measuring Information Gain for Frequency-Encoded Super-Resolution {{MRI}}},
  author = {Mayer, Gregory S. and Vrscay, Edward R.},
  date = {2007-09},
  journaltitle = {Magnetic Resonance Imaging},
  shortjournal = {Magnetic Resonance Imaging},
  volume = {25},
  number = {7},
  pages = {1058--1069},
  publisher = {Elsevier BV},
  issn = {0730725X},
  doi = {10.1016/j.mri.2006.12.006},
  url = {https://linkinghub.elsevier.com/retrieve/pii/S0730725X06004243},
  urldate = {2026-03-13},
  abstract = {Super-resolution (SR)-based methods that implement multiple data sets related by spatial translations in the frequency-encoding (FE) direction have recently been proposed for resolution enhancement in MRI. This approach, however, was initially received with controversy. It was suggested that when the shifts are applied in the FE direction, no new information was acquired after the first image. Recent developments suggest, however, that shifting the object between image acquisitions can introduce new information to each data set. For this reason, SRMRI may be possible in the FE direction.},
  langid = {english}
}

@article{mazurekDetectionIntracerebralHemorrhage2023,
  title = {Detection of {{Intracerebral Hemorrhage Using Low-Field}}, {{Portable Magnetic Resonance Imaging}} in {{Patients With Stroke}}},
  author = {Mazurek, Mercy H. and Parasuram, Nethra R. and Peng, Teng J. and Beekman, Rachel and Yadlapalli, Vineetha and Sorby-Adams, Annabel J. and Lalwani, Dheeraj and Zabinska, Julia and Gilmore, Emily J. and Petersen, Nils H. and Falcone, Guido J. and Sujijantarat, Nanthiya and Matouk, Charles and Payabvash, Sam and Sze, Gordon and Schiff, Steven J. and Iglesias, Juan Eugenio and Rosen, Matthew S. and De Havenon, Adam and Kimberly, W. Taylor and Sheth, Kevin N.},
  date = {2023-11},
  journaltitle = {Stroke},
  shortjournal = {Stroke},
  volume = {54},
  number = {11},
  pages = {2832--2841},
  issn = {0039-2499, 1524-4628},
  doi = {10.1161/STROKEAHA.123.043146},
  url = {https://www.ahajournals.org/doi/10.1161/STROKEAHA.123.043146},
  urldate = {2026-03-13},
  abstract = {BACKGROUND: Neuroimaging is essential for detecting spontaneous, nontraumatic intracerebral hemorrhage (ICH). Recent data suggest ICH can be characterized using low-field magnetic resonance imaging (MRI). Our primary objective was to investigate the sensitivity and specificity of ICH on a 0.064T portable MRI (pMRI) scanner using a methodology that provided clinical information to inform rater interpretations. As a secondary aim, we investigated whether the incorporation of a deep learning (DL) reconstruction algorithm affected ICH detection. METHODS: The pMRI device was deployed at Yale New Haven Hospital to examine patients presenting with stroke symptoms from October 26, 2020 to February 21, 2022. Three raters independently evaluated pMRI examinations. Raters were provided the images alongside the patient's clinical information to simulate real-world context of use. Ground truth was the closest conventional computed tomography or 1.5/3T MRI. Sensitivity and specificity results were grouped by DL and nonDL software to investigate the effects of software advances. RESULTS: A total of 189 exams (38 ICH, 89 acute ischemic stroke, 8 subarachnoid hemorrhage, 3 primary intraventricular hemorrhage, 51 no intracranial abnormality) were evaluated. Exams were correctly classified as positive or negative for ICH in 185 of 189 cases (97.9\% overall accuracy). ICH was correctly detected in 35 of 38 cases (92.1\% sensitivity). Ischemic stroke and no intracranial abnormality cases were correctly identified as blood-negative in 139 of 140 cases (99.3\% specificity). Non-DL scans had a sensitivity and specificity for ICH of 77.8\% and 97.1\%, respectively. DL scans had a sensitivity and specificity for ICH of 96.6\% and 99.3\%, respectively. CONCLUSIONS: These results demonstrate improvements in ICH detection accuracy on pMRI that may be attributed to the integration of clinical information in rater review and the incorporation of a DL-based algorithm. The use of pMRI holds promise in providing diagnostic neuroimaging for patients with ICH.},
  langid = {english}
}

@misc{Mcrobbie2007MRI,
  title = {{{MRI From Picture}} to {{Proton}}},
  author = {Mcrobbie, Donald W and Moore, Elizabeth A and Graves, Martin J and Prince, Martin R},
  date = {2007-12-07},
  abstract = {MRI from Picture to Proton presents the basics of MR practice and theory as the practitioner first meets them. The subject is approached intuitively: starting from the images, equipment and scanning protocols, rather than pages of dry physics theory. The reader is brought faceto-face with issues pertinent to practice immediately, filling in the theoretical background as their scanning experience grows. Key ideas are introduced in an intuitive manner which is faithful to the underlying physics but avoids the need for difficult or distracting mathematics. Additional explanations for the more technically inquisitive are given in optional secondary text boxes. Informal in style, informed in content, written by experienced teachers, MRI from Picture to Proton is an essential text for the student of MR whatever their background: medical, technical or scientific.}
}

@article{Meneses2023Liver,
  title = {Liver {{PDFF}} Estimation Using a Multi-Decoder Water-Fat Separation Neural Network with a Reduced Number of Echoes},
  author = {Meneses, Juan Pablo and Arrieta, Cristobal and family=Maggiora, given=Gabriel, prefix=della, useprefix=true and Besa, Cecilia and Urbina, Jes\'us and Arrese, Marco and Gana, Juan Crist\'obal and Galgani, Jose E. and Tejos, Cristian and Uribe, Sergio},
  author+an:orcid = {1="https://orcid.org/0000-0003-3313-5713"},
  date = {2023-04-04},
  journaltitle = {European Radiology},
  shortjournal = {Eur Radiol},
  volume = {33},
  number = {9},
  pages = {6557--6568},
  publisher = {{Springer Science and Business Media LLC}},
  issn = {1432-1084},
  doi = {10.1007/s00330-023-09576-2},
  url = {http://dx.doi.org/10.1007/s00330-023-09576-2},
  urldate = {2026-03-17},
  abstract = {{$<$}jats:title{$>$}Abstract{$<$}/jats:title{$><$}jats:sec{$>$} {$<$}jats:title{$>$}Objective{$<$}/jats:title{$>$} {$<$}jats:p{$>$}To accurately estimate liver {$<$}jats:italic{$>$}PDFF{$<$}/jats:italic{$>$} from chemical shift-encoded (CSE) MRI using a deep learning (DL)-based Multi-Decoder Water-Fat separation Network (MDWF-Net), that operates over complex-valued CSE-MR images with only 3 echoes.{$<$}/jats:p{$>$} {$<$}/jats:sec{$><$}jats:sec{$>$} {$<$}jats:title{$>$}Methods {$<$}/jats:title{$>$} {$<$}jats:p{$>$}The proposed MDWF-Net and a U-Net model were independently trained using the first 3 echoes of MRI data from 134 subjects, acquired with conventional 6-echoes abdomen protocol at 1.5 T. Resulting models were then evaluated using unseen CSE-MR images obtained from 14 subjects that were acquired with a 3-echoes CSE-MR pulse sequence with a shorter duration compared to the standard protocol. Resulting PDFF maps were qualitatively assessed by two radiologists, and quantitatively assessed at two corresponding liver ROIs, using Bland Altman and regression analysis for mean values, and ANOVA testing for standard deviation (STD) (significance level: .05). A 6-echo graph cut was considered ground truth.{$<$}/jats:p{$>$} {$<$}/jats:sec{$><$}jats:sec{$>$} {$<$}jats:title{$>$}Results{$<$}/jats:title{$>$} {$<$}jats:p{$>$}Assessment of radiologists demonstrated that, unlike U-Net, MDWF-Net had a similar quality to the ground truth, despite it considered half of the information. Regarding {$<$}jats:italic{$>$}PDFF{$<$}/jats:italic{$>$} mean values at ROIs, MDWF-Net showed a better agreement with ground truth (regression slope = 0.94, {$<$}jats:italic{$>$}R{$<$}/jats:italic{$><$}jats:sup{$>$}2{$<$}/jats:sup{$>$} = 0.97) than U-Net (regression slope = 0.86, {$<$}jats:italic{$>$}R{$<$}/jats:italic{$><$}jats:sup{$>$}2{$<$}/jats:sup{$>$} = 0.93). Moreover, ANOVA post hoc analysis of STDs showed a statistical difference between graph cuts and U-Net ({$<$}jats:italic{$>$}p{$<$}/jats:italic{$>$} \&lt; .05), unlike MDWF-Net ({$<$}jats:italic{$>$}p{$<$}/jats:italic{$>$} = .53).{$<$}/jats:p{$>$} {$<$}/jats:sec{$><$}jats:sec{$>$} {$<$}jats:title{$>$}Conclusion{$<$}/jats:title{$>$} {$<$}jats:p{$>$}MDWF-Net showed a liver {$<$}jats:italic{$>$}PDFF{$<$}/jats:italic{$>$} accuracy comparable to the reference graph cut method, using only 3 echoes and thus allowing a reduction in the acquisition times.{$<$}/jats:p{$>$} {$<$}/jats:sec{$><$}jats:sec{$>$} {$<$}jats:title{$>$}Clinical relevance statement{$<$}/jats:title{$>$} {$<$}jats:p{$>$}We have prospectively validated that the use of a multi-decoder convolutional neural network to estimate liver proton density fat fraction allows a significant reduction in MR scan time by reducing the number of echoes required by 50{$<$}/jats:sec{$><$}jats:sec{$>$} {$<$}jats:title{$>$}Key Points{$<$}/jats:title{$>$} {$<$}jats:p{$>\bullet$} {$<$}jats:italic{$>$}Novel water-fat separation neural network allows for liver PDFF estimation by using multi-echo MR images with a reduced number of echoes{$<$}/jats:italic{$>$}.{$<$}/jats:p{$>$} {$<$}jats:p{$>\bullet$} {$<$}jats:italic{$>$}Prospective single-center validation demonstrated that echo reduction leads to a significant shortening of the scan time, compared to standard 6-echo acquisition{$<$}/jats:italic{$>$}.{$<$}/jats:p{$>$} {$<$}jats:p{$>\bullet$} {$<$}jats:italic{$>$}Qualitative and quantitative performance of the proposed method showed no significant differences in PDFF estimation with respect to the reference technique{$<$}/jats:italic{$>$}.{$<$}/jats:p{$>$} {$<$}/jats:sec{$>$}},
  langid = {english}
}

@article{menesesUnbiasedReproducibleLiver2024,
  title = {Unbiased and Reproducible Liver {{MRI-PDFF}} Estimation Using a Scan Protocol-Informed Deep Learning Method},
  author = {Meneses, Juan P. and Qadir, Ayyaz and Surendran, Nirusha and Arrieta, Cristobal and Tejos, Cristian and Andia, Marcelo E. and Chen, Zhaolin and Uribe, Sergio},
  date = {2024-11-05},
  journaltitle = {European Radiology},
  shortjournal = {Eur Radiol},
  volume = {35},
  number = {5},
  pages = {2843--2854},
  issn = {1432-1084},
  doi = {10.1007/s00330-024-11164-x},
  url = {https://link.springer.com/10.1007/s00330-024-11164-x},
  urldate = {2026-03-13},
  abstract = {Objective To estimate proton density fat fraction (PDFF) from chemical shift encoded (CSE) MR images using a deep learning (DL)-based method that is precise and robust to different MR scanners and acquisition echo times (TEs). Methods Variable echo times neural network (VET-Net) is a two-stage framework that first estimates nonlinear variables of the CSE-MR signal model, to posteriorly estimate water/fat signal components using the least-squares method. VET-Net incorporates a vector with TEs as an auxiliary input, therefore enabling PDFF calculation with any TE setting. A single-site liver CSE-MRI dataset (188 subjects, 4146 axial slices) was considered, which was split into training (150 subjects), validation (18), and testing (20) subsets. Testing subjects were scanned using several protocols with different TEs, which we then used to measure the PDFF reproducibility coefficient (RDC) at two regions of interest (ROIs): the right posterior and left hepatic lobes. An open-source multi-site and multi-vendor fat--water phantom dataset was also used for PDFF bias assessment. Results VET-Net showed RDCs of 1.71\% and 1.04\% on the right posterior and left hepatic lobes, respectively, across different TEs, which was comparable to a reference graph cuts-based method (RDCs = 1.71\% and 0.86\%). VET-Net also showed a smaller PDFF bias (-0.55\%) than graph cuts (0.93\%) when tested on a multi-site phantom dataset. Reproducibility (1.94\% and 1.59\%) and bias (-2.04\%) were negatively affected when the auxiliary TE input was not considered. Conclusion VET-Net provided unbiased and precise PDFF estimations using CSE-MR images from different hardware vendors and different TEs, outperforming conventional DL approaches.},
  langid = {english}
}

