@article{van2024GPUaccelerated,
  title = {{{GPUaccelerated Bloch}} Simulations and {{MRSTAT}} Reconstructions Using the {{Julia}} Programming Language},
  author = {family=Heide, given=Oscar, prefix=van der, useprefix=true and family=Berg, given=Cornelis A. T., prefix=van den, useprefix=true and Sbrizzi, Alessandro},
  author+an:orcid = {1="http://orcid.org/0000-0002-8451-525X"; 2="http://orcid.org/0000-0002-5565-6889"; 3="http://orcid.org/0000-0003-3276-4542"},
  date = {2024-03-05},
  journaltitle = {Magnetic Resonance in Medicine},
  shortjournal = {Magnetic Resonance in Med},
  volume = {92},
  number = {2},
  pages = {618--630},
  publisher = {Wiley},
  issn = {0740-3194},
  doi = {10.1002/mrm.30074},
  url = {http://dx.doi.org/10.1002/mrm.30074},
  abstract = {{$<$}jats:title{$>$}Abstract{$<$}/jats:title{$><$}jats:sec{$><$}jats:title{$>$}Purpose{$<$}/jats:title{$><$}jats:p{$>$}MRSTAT is a relatively new multiparametric quantitative MRI technique in which quantitative paramater maps are obtained by solving a largescale nonlinear optimization problem. Managing reconstruction times is one of the main challenges of MRSTAT. In this work we leverage GPU hardware to reduce MRSTAT reconstruction times. A highly optimized, GPUcompatible Bloch simulation toolbox is developed as part of this work that can be utilized for other quantitative MRI techniques as well.{$<$}/jats:p{$><$}/jats:sec{$><$}jats:sec{$><$}jats:title{$>$}Methods{$<$}/jats:title{$><$}jats:p{$>$}The Julia programming language was used to develop a flexible yet highly performant and GPUcompatible Bloch simulation toolbox called BlochSimulators.jl. The runtime performance of the toolbox is benchmarked against other Bloch simulation toolboxes. Furthermore, a (partially matrixfree) modification of a previously presented (matrixfree) MRSTAT reconstruction algorithm is proposed and implemented using the Julia language on GPU hardware. The proposed algorithm is combined with BlochSimulators.jl and the resulting MRSTAT reconstruction times on GPU hardware are compared to previously presented MRSTAT reconstruction times.{$<$}/jats:p{$><$}/jats:sec{$><$}jats:sec{$><$}jats:title{$>$}Results{$<$}/jats:title{$><$}jats:p{$>$}The BlochSimulators.jl package demonstrates superior runtime performance on both CPU and GPU hardware when compared to other existing Bloch simulation toolboxes. The GPUaccelerated partially matrixfree MRSTAT reconstruction algorithm, which relies on BlochSimulators.jl, allows for reconstructions of 68 seconds per twodimensional (2D slice).{$<$}/jats:p{$><$}/jats:sec{$><$}jats:sec{$><$}jats:title{$>$}Conclusion{$<$}/jats:title{$><$}jats:p{$>$}By combining the proposed Bloch simulation toolbox and the partially matrixfree reconstruction algorithm, 2D MRSTAT reconstructions can be performed in the order of one minute on a modern GPU card. The Bloch simulation toolbox can be utilized for other quantitative MRI techniques as well, for example for online dictionary generation for MR Fingerprinting.{$<$}/jats:p{$><$}/jats:sec{$>$}},
  langid = {english}
}

@inproceedings{vanameromFetalCardiac3D,
  title = {Fetal Cardiac {{3D}} Cine {{MRI}} at Low Field - Whole Heart Slice-to-Volume Reconstruction from Real-Time Spiral {{SSFP}} at 0.{{55T}}},
  author = {Van Amerom, Joshua and Tian, Ye and Goolaub, Datta and Wood, John and Detterich, Jon and Nayak, Krishna and Macgowan, Christopher},
  pages = {0548},
  location = {Toronto, ON, Canada},
  doi = {10.58530/2023/0548},
  url = {https://archive.ismrm.org/2023/0548.html},
  urldate = {2026-03-13},
  abstract = {Spiral SSFP of the fetal heart at low-field has the advantage of low artifact and high sampling efficiency, compared to conventional systems. This work demonstrates the feasibility of spiral SSFP on a high-performance 0.55 T scanner to produce high spatiotemporal resolution real-time 2D and motion-corrected slice-to-volume super-resolution reconstructed 3D cine images of the heart and great vessels of the human fetus in utero. Patient comfort is improved with the use of a low-field scanner, while motion-robust slice-to-volume reconstruction allows for free-breathing acquisitions that do not require precise scan plane prescriptions during acquisition.},
  eventtitle = {2023 {{ISMRM}} \& {{ISMRT Annual Meeting}}},
  langid = {english}
}

@article{vanbeekValueMRIMedicine2019,
  title = {Value of {{MRI}} in Medicine: {{More}} than Just Another Test?},
  shorttitle = {Value of {{MRI}} in Medicine},
  author = {Van Beek, Edwin J.R. and Kuhl, Christiane and Anzai, Yoshimi and Desmond, Patricia and Ehman, Richard L. and Gong, Qiyong and Gold, Garry and Gulani, Vikas and Hall-Craggs, Margaret and Leiner, Tim and Lim, C.C. Tschoyoson and Pipe, James G. and Reeder, Scott and Reinhold, Caroline and Smits, Marion and Sodickson, Daniel K. and Tempany, Clare and Vargas, H. Alberto and Wang, Meiyun},
  date = {2019-06},
  journaltitle = {Journal of Magnetic Resonance Imaging},
  shortjournal = {Magnetic Resonance Imaging},
  volume = {49},
  number = {7},
  issn = {1053-1807, 1522-2586},
  doi = {10.1002/jmri.26211},
  url = {https://onlinelibrary.wiley.com/doi/10.1002/jmri.26211},
  urldate = {2026-03-13},
  abstract = {There is increasing scrutiny from healthcare organizations towards the utility and associated costs of imaging. MRI has traditionally been used as a high-end modality, and although shown extremely important for many types of clinical scenarios, it has been suggested as too expensive by some. This editorial will try and explain how value should be addressed and gives some insights and practical examples of how value of MRI can be increased. It requires a global effort to increase accessibility, value for money, and impact on patient management. We hope this editorial sheds some light and gives some indications of where the field may wish to address some of its research to proactively demonstrate the value of MRI.                                Level of Evidence                 : 5                                               Technical Efficacy                 : Stage 5                              J. Magn. Reson. Imaging 2019;49:e14--e25.},
  langid = {english}
}

