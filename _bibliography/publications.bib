@article{Hu2024Efficient,
  title = {Efficient Pulse Sequence Design Framework for Highdimensional {$<$}scp{$>$}{{MR}}{$<$}/Scp{$>$} Fingerprinting Scans Using Systematic Error Index},
  author = {Hu, Siyuan and Qiu, Zhilang and Adams, Richard James and Zhao, Walter and Boyacioglu, Rasim and Calvetti, Daniela and McGivney, Debra and Ma, Dan},
  author+an:orcid = {1="http://orcid.org/0000-0003-3137-0605"; 2="http://orcid.org/0000-0002-8327-2233"; 4="http://orcid.org/0000-0001-8907-4935"; 5="http://orcid.org/0000-0002-3099-2640"; 7="http://orcid.org/0000-0003-2059-6107"; 8="http://orcid.org/0000-0003-1664-9579"},
  date = {2024-05-09},
  journaltitle = {Magnetic Resonance in Medicine},
  shortjournal = {Magnetic Resonance in Med},
  volume = {92},
  number = {4},
  pages = {1600--1616},
  publisher = {Wiley},
  issn = {0740-3194},
  doi = {10.1002/mrm.30155},
  url = {http://dx.doi.org/10.1002/mrm.30155},
  abstract = {{$<$}jats:title{$>$}Abstract{$<$}/jats:title{$><$}jats:sec{$><$}jats:title{$>$}Purpose{$<$}/jats:title{$><$}jats:p{$>$}For effective optimization of MR fingerprinting (MRF) pulse sequences, estimating and minimizing errors from actual scan conditions are crucial. Although virtualscan simulations offer an approximation to these errors, their computational demands become expensive for highdimensional MRF frameworks, where interactions between more than two tissue properties are considered. This complexity makes sequence optimization impractical. We introduce a new mathematical model, the systematic error index (SEI), to address the scalability challenges for highdimensional MRF sequence design.{$<$}/jats:p{$><$}/jats:sec{$><$}jats:sec{$><$}jats:title{$>$}Methods{$<$}/jats:title{$><$}jats:p{$>$}By eliminating the need to perform dictionary matching, the SEI model approximates quantification errors with low computational costs. The SEI model was validated in comparison with virtualscan simulations. The SEI model was further applied to optimize three highdimensional MRF sequences that quantify two to four tissue properties. The optimized scans were examined in simulations and healthy subjects.{$<$}/jats:p{$><$}/jats:sec{$><$}jats:sec{$><$}jats:title{$>$}Results{$<$}/jats:title{$><$}jats:p{$>$}The proposed SEI model closely approximated the virtualscan simulation outcomes while achieving hundred to thousandtimes acceleration in the computational speed. In both simulation and in vivo experiments, the optimized MRF sequences yield higher measurement accuracy with fewer undersampling artifacts at shorter scan times than the heuristically designed sequences.{$<$}/jats:p{$><$}/jats:sec{$><$}jats:sec{$><$}jats:title{$>$}Conclusion{$<$}/jats:title{$><$}jats:p{$>$}We developed an efficient method for estimating realworld errors in MRF scans with high computational efficiency. Our results illustrate that the SEI model could approximate errors both qualitatively and quantitatively. We also proved the practicality of the SEI model of optimizing sequences for highdimensional MRF frameworks with manageable computational power. The optimized highdimensional MRF scans exhibited enhanced robustness against undersampling and system imperfections with faster scan times.{$<$}/jats:p{$><$}/jats:sec{$>$}},
  langid = {english}
}

@article{Huang2023High,
  title = {High-Efficient {{Bloch}} Simulation of Magnetic Resonance Imaging Sequences Based on Deep Learning},
  author = {Huang, Haitao and Yang, Qinqin and Wang, Jiechao and Zhang, Pujie and Cai, Shuhui and Cai, Congbo},
  author+an:orcid = {2="https://orcid.org/0000-0002-8927-3931"; 5="https://orcid.org/0000-0003-2767-9490"},
  date = {2023-04-03},
  journaltitle = {Physics in Medicine \&amp; Biology},
  shortjournal = {Phys. Med. Biol.},
  volume = {68},
  number = {8},
  pages = {085002},
  publisher = {IOP Publishing},
  issn = {0031-9155},
  doi = {10.1088/1361-6560/acc4a6},
  url = {http://dx.doi.org/10.1088/1361-6560/acc4a6},
  abstract = {{$<$}jats:title{$>$}Abstract{$<$}/jats:title{$>$} {$<$}jats:p{$>$} {$<$}jats:italic{$>$}Objective{$<$}/jats:italic{$>$}. Bloch simulation constitutes an essential part of magnetic resonance imaging (MRI) development. However, even with the graphics processing unit (GPU) acceleration, the heavy computational load remains a major challenge, especially in large-scale, high-accuracy simulation scenarios. This work aims to develop a deep learning-based simulator to accelerate Bloch simulation. {$<$}jats:italic{$>$}Approach{$<$}/jats:italic{$>$}. The simulator model, called Simu-Net, is based on an end-to-end convolutional neural network and is trained with synthetic data generated by traditional Bloch simulation. It uses dynamic convolution to fuse spatial and physical information with different dimensions and introduces position encoding templates to achieve position-specific labeling and overcome the receptive field limitation of the convolutional network. {$<$}jats:italic{$>$}Main results{$<$}/jats:italic{$>$}. Compared with mainstream GPU-based MRI simulation software, Simu-Net successfully accelerates simulations by hundreds of times in both traditional and advanced MRI pulse sequences. The accuracy and robustness of the proposed framework were verified qualitatively and quantitatively. Besides, the trained Simu-Net was applied to generate sufficient customized training samples for deep learning-based {$<$}jats:italic{$>$}T{$<$}/jats:italic{$>$} {$<$}jats:sub{$>$}2{$<$}/jats:sub{$>$} mapping and comparable results to conventional methods were obtained in the human brain. {$<$}jats:italic{$>$}Significance{$<$}/jats:italic{$>$}. As a proof-of-concept work, Simu-Net shows the potential to apply deep learning for rapidly approximating the forward physical process of MRI and may increase the efficiency of Bloch simulation for optimization of MRI pulse sequences and deep learning-based methods.{$<$}/jats:p{$>$}}
}

