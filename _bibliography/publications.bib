@article{Allan2012OMERO,
  title = {{{OMERO}}: Flexible, Model-Driven Data Management for Experimental Biology},
  shorttitle = {{{OMERO}}},
  author = {Allan, Chris and Burel, Jean-Marie and Moore, Josh and Blackburn, Colin and Linkert, Melissa and Loynton, Scott and MacDonald, Donald and Moore, William J and Neves, Carlos and Patterson, Andrew and Porter, Michael and Tarkowska, Aleksandra and Loranger, Brian and Avondo, Jerome and Lagerstedt, Ingvar and Lianas, Luca and Leo, Simone and Hands, Katherine and Hay, Ron T and Patwardhan, Ardan and Best, Christoph and Kleywegt, Gerard J and Zanetti, Gianluigi and Swedlow, Jason R},
  date = {2012-03},
  journaltitle = {Nature Methods},
  shortjournal = {Nat Methods},
  volume = {9},
  number = {3},
  pages = {245--253},
  publisher = {{Springer Science and Business Media LLC}},
  issn = {1548-7091, 1548-7105},
  doi = {10.1038/nmeth.1896},
  url = {https://www.nature.com/articles/nmeth.1896},
  urldate = {2026-03-13},
  abstract = {Data-intensive research depends on tools that manage multi-dimensional, heterogeneous data sets. We have built OME Remote Objects (OMERO), a software platform that enables access to and use of a wide range of biological data. OMERO uses a server-based middleware application to provide a unified interface for images, matrices, and tables. OMERO's design and flexibility have enabled its use for light microscopy, high content screening, electron microscopy, and even nonimage genotype data. OMERO is open source software and available at http:// openmicroscopy.org.},
  langid = {english}
}

