@article{velagapudiLowFieldPortableMR2024,
  title = {Low-{{Field Portable MR Imaging}} to {{Evaluate Ventricular Volumes}}: {{A Single-Center Retrospective Study}}},
  shorttitle = {Low-{{Field Portable MR Imaging}} to {{Evaluate Ventricular Volumes}}},
  author = {Velagapudi, Vivek and Artz, Nathan S. and Fite, Johnston K. and Chan, Sherwin S. and Rouse, Adam G.},
