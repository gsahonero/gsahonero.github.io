@article{Korda2022Identification,
  title = {Identification of Texture {{MRI}} Brain Abnormalities on First-Episode Psychosis and Clinical High-Risk Subjects Using Explainable Artificial Intelligence},
  author = {Korda, Alexandra I. and Andreou, Christina and Rogg, Helena Victoria and Avram, Mihai and Ruef, Anne and Davatzikos, Christos and Koutsouleris, Nikolaos and Borgwardt, Stefan},
  author+an:orcid = {1="https://orcid.org/0000-0001-8843-4951"; 2="https://orcid.org/0000-0002-6656-9043"; 6="https://orcid.org/0000-0002-1025-8561"; 7="https://orcid.org/0000-0001-6825-6262"},
  date = {2022-11-16},
  journaltitle = {Translational Psychiatry},
  shortjournal = {Transl Psychiatry},
  volume = {12},
  number = {1},
  publisher = {{Springer Science and Business Media LLC}},
  issn = {2158-3188},
  doi = {10.1038/s41398-022-02242-z},
  url = {http://dx.doi.org/10.1038/s41398-022-02242-z},
  abstract = {{$<$}jats:title{$>$}Abstract{$<$}/jats:title{$><$}jats:p{$>$}Structural MRI studies in first-episode psychosis and the clinical high-risk state have consistently shown volumetric abnormalities. Aim of the present study was to introduce radiomics texture features in identification of psychosis. Radiomics texture features describe the interrelationship between voxel intensities across multiple spatial scales capturing the hidden information of underlying disease dynamics in addition to volumetric changes. Structural MR images were acquired from 77 first-episode psychosis (FEP) patients, 58 clinical high-risk subjects with no later transition to psychosis (CHR\_NT), 15 clinical high-risk subjects with later transition (CHR\_T), and 44 healthy controls (HC). Radiomics texture features were extracted from non-segmented images, and two-classification schemas were performed for the identification of FEP vs. HC and FEP vs. CHR\_NT. The group of CHR\_T was used as external validation in both schemas. The classification of a subject's clinical status was predicted by importing separately (a) the difference of entropy feature map and (b) the contrast feature map, resulting in classification balanced accuracy above 72},
  langid = {english}
}

@article{Kozyrska2022p53,
  title = {P53 Directs Leader Cell Behavior, Migration, and Clearance during Epithelial Repair},
  author = {Kozyrska, Kasia and Pilia, Giulia and Vishwakarma, Medhavi and Wagstaff, Laura and Goschorska, Maja and Cirillo, Silvia and Mohamad, Saad and Gallacher, Kelli and Carazo Salas, Rafael E. and Piddini, Eugenia},
  author+an:orcid = {1="http://orcid.org/0000-0001-5585-655X"; 2="http://orcid.org/0000-0003-1311-4827"; 5="http://orcid.org/0000-0002-7330-9506"; 6="http://orcid.org/0000-0002-9039-0326"; 8="http://orcid.org/0000-0001-6551-8968"; 9="http://orcid.org/0000-0002-5943-3981"; 10="http://orcid.org/0000-0003-3901-076X"},
  date = {2022-02-11},
  journaltitle = {Science},
  shortjournal = {Science},
  volume = {375},
  number = {6581},
  pages = {eabl8876},
  publisher = {American Association for the Advancement of Science (AAAS)},
  issn = {0036-8075, 1095-9203},
  doi = {10.1126/science.abl8876},
  url = {https://www.science.org/doi/10.1126/science.abl8876},
  urldate = {2026-03-13},
  abstract = {Epithelial cells migrate across wounds to repair injured tissue. Leader cells at the front of migrating sheets often drive this process. However, it is unclear how leaders emerge from an apparently homogeneous epithelial cell population. Here, we characterized leaders emerging from epithelial monolayers in cell culture and found that they activated the stress sensor p53, which was sufficient to initiate leader cell behavior. p53 activated the cell cycle inhibitor p21WAF1/Cip1, which in turn induced leader behavior via inhibition of cyclin-dependent kinase (CDK) activity. p53 also induced crowding hypersensitivity in leader cells such that, upon epithelial closure, they were eliminated by cell competition. Thus, mechanically-induced p53 directs emergence of a transient population of leader cells that drive migration and ensures their clearance upon epithelial repair.},
  langid = {english}
}

